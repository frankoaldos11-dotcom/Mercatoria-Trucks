# ──────────────────────────────────────────────
# MERCATORIA TRUCK — Variables de entorno
# Copia este archivo como .env y completa los valores.
# NUNCA subas .env al repositorio.
# ──────────────────────────────────────────────

# Clave secreta de Flask (obligatoria — genera una con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambia-esto-por-una-clave-segura-generada-aleatoriamente

# Base de datos
# Si se define DATABASE_URL la app usa PostgreSQL; si no, usa SQLite local.
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_base_datos

# Migraciones PostgreSQL
# Establecer en "true" para saltar la ejecución automática de migraciones al arrancar.
SKIP_MIGRATIONS=false

# ── Correo electrónico (Flask-Mail) ───────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu-cuenta@gmail.com
MAIL_PASSWORD=tu-app-password-de-gmail
MAIL_DEFAULT_SENDER=noreply@mercatoriatruck.com
